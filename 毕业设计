import msvcrt  # 导入 Windows 专用的键盘监听库
from geopy.distance import geodesic  # 导入地理距离计算库

# 拓扑连接表
MY_TOPOLOGY = {
    'R1': ['R2', 'R3', 'R4'],  # 深圳
    'R2': ['R1', 'R3', 'R5'],  # 广州
    'R3': ['R1', 'R2', 'R4', 'R6'],  # 武汉
    'R4': ['R1', 'R3', 'R7'],  # 长沙
    'R5': ['R2', 'R6', 'R8'],  # 南昌
